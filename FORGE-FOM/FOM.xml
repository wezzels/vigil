        </enumerationClass>
        
        <enumerationClass name="DetonationResultEnumerated">
            <enumerator name="Other" value="0"/>
            <enumerator name="Impact" value="1"/>
            <enumerator name="Detonation" value="2"/>
            <enumerator name="None" value="3"/>
            <enumerator name="Small" value="4"/>
            <enumerator name="Medium" value="5"/>
            <enumerator name="Large" value="6"/>
            <enumerator name="KilledByGracefulDetonation" value="7"/>
        </enumerationClass>
        
        <enumerationClass name="WarheadFunctionEnumerated">
