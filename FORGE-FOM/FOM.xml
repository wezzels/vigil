            <enumerator name="EchelonLeft" value="4"/>
            <enumerator name="Box" value="5"/>
            <enumerator name="Vee" value="6"/>
            <enumerator name="Diamond" value="7"/>
        </enumerationClass>
        
        <enumerationClass name="AggregateStateEnumerated">
            <enumerator name="Forming" value="0"/>
            <enumerator name="Assembled" value="1"/>
            <enumerator name="Dispersed" value="2"/>
            <enumerator name="Engaged" value="3"/>
            <enumerator name="Neutralized" value="4"/>
            <enumerator name="Failed" value="5"/>
        </enumerationClass>
        
    </supplementalObjects>
    
    <dataTypes>
        
        <!-- Entity Identifier: Site/Application/Entity tuple -->
        <simpleDataType name="EntityIdentifier" representation="EntityIdentifierRecord" />
        
        <!-- World Coordinates: Geodetic/ECEF position -->
        <simpleDataType name="WorldCoordinate" representation="WorldCoordinateRecord" />
        
        <!-- Velocity Vector: m/s in entity axis -->
        <simpleDataType name="VelocityVector" representation="VelocityVectorRecord" />
        
        <!-- Orientation: Yaw/Pitch/Roll in radians -->
        <simpleDataType name="Orientation" representation="OrientationRecord" />
        
        <!-- Acceleration Vector -->
        <simpleDataType name="AccelerationVector" representation="AccelerationVectorRecord" />
        
        <!-- Angular Velocity Vector -->
        <simpleDataType name="AngularVelocityVector" representation="AngularVelocityVectorRecord" />
        
        <!-- Entity Type Record: Kind/Domain/Country/Category/Subcategory/Specific -->
        <simpleDataType name="EntityTypeRecord" representation="EntityTypeRecordData" />
        
        <!-- Munition Record -->
        <simpleDataType name="MunitionRecord" representation="MunitionRecordData" />
        
        <!-- Fire Event Record -->
        <simpleDataType name="FireEventRecord" representation="FireEventRecordData" />
        
        <!-- Detonation Event Record -->
        <simpleDataType name="DetonationEventRecord" representation="DetonationEventRecordData" />
        
        <!-- Impact Prediction Record -->
        <simpleDataType name="ImpactPredictionRecord" representation="ImpactPredictionRecordData" />
        
        <!-- Event Identifier -->
        <simpleDataType name="EventIdentifier" representation="EventIdentifierRecordData" />
        
        <!-- Radio Type Record -->
        <simpleDataType name="RadioTypeRecord" representation="RadioTypeRecordData" />
        
        <!-- Modulation Record -->
        <simpleDataType name="ModulationRecord" representation="ModulationRecordData" />
        
        <!-- Antenna Pattern Record -->
        <simpleDataType name="AntennaPatternRecord" representation="AntennaPatternRecordData" />
        
        <!-- Formation Record -->
        <simpleDataType name="FormationRecord" representation="FormationRecordData" />
        
        <!-- Environmental Type Record -->
        <simpleDataType name="EnvironmentalTypeRecord" representation="EnvironmentalTypeRecordData" />
        
        <!-- Extents Record: Bounding area/volume -->
        <simpleDataType name="ExtentsRecord" representation="ExtentsRecordData" />
        
        <!-- FOV Record: Sensor field of view -->
        <simpleDataType name="FOVRecord" representation="FOVRecordData" />
        
        <!-- Articulation Parameter -->
        <simpleDataType name="ArticulationParameter" representation="ArticulationParameterRecordData" />
        
        <!-- Fusing Record -->
        <simpleDataType name="FusingRecord" representation="FusingRecordData" />
        
        <!-- Environmental State Enumerated -->
        <simpleDataType name="EnvironmentalStateEnumerated" representation="HLAinteger16BE" />
        
        <!-- Transmit State Enumerated -->
        <simpleDataType name="TransmitStateEnumerated" representation="HLAinteger16BE" />
        
        <!-- Munition Detonation Record -->
        <simpleDataType name="MunitionDetonationRecord" representation="MunitionDetonationRecordData" />
        
        <!-- Supplement Record -->
        <simpleDataType name="SupplementRecord" representation="SupplementRecordData" />
        
        <!-- Command Type Enumerated -->
        <simpleDataType name="CommandTypeEnumerated" representation="HLAinteger16BE" />
        
        <!-- Mission Record -->
        <simpleDataType name="MissionRecord" representation="MissionRecordData" />
        
        <!-- Query Type Enumerated -->
        <simpleDataType name="QueryTypeEnumerated" representation="HLAinteger16BE" />
        
        <!-- Environmental Report Type -->
        <simpleDataType name="EnvironmentalReportType" representation="HLAinteger16BE" />
        
        <!-- Emission Type Record -->
        <simpleDataType name="EmissionTypeRecord" representation="EmissionTypeRecordData" />
        
    </dataTypes>
    
</federationObjectModel>
