            <enumerator name="Artillery" value="8"/>
            <enumerator name="Mortar" value="9"/>
            <enumerator name="Rocket" value="10"/>
        </enumerationClass>
        
        <enumerationClass name="AlertLevelEnumerated">
            <enumerator name="Unknown" value="0"/>
            <enumerator name="CONOPREP" value="1"/>
            <enumerator name="IMMINENT" value="2"/>
            <enumerator name="INCOMING" value="3"/>
            <enumerator name="HOSTILE" value="4"/>
