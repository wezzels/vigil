        <enumerationClass name="SensorSourceEnumerated">
            <enumerator name="Unknown" value="0"/>
            <enumerator name="SBIRS_HIGH" value="1"/>
            <enumerator name="SBIRS_LOW" value="2"/>
            <enumerator name="NG_OPIR" value="3"/>
